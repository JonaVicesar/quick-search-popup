{
  "manifest_version": 3,
  "name": "Quick Search Popup",
  "version": "1.0.0",
  "description": "Search from a compact popup and browse results without leaving it.",
  "browser_specific_settings": {
    "gecko": {
      "id": "quick-search-popup@jona.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quick Search Popup"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+Space" },
      "description": "Open Popup"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
