{
  "manifest_version": 3,
  "name": "Quick Search Popup",
  "version": "1.0.0",
  "description": "...",
  "browser_specific_settings": {
    "gecko": {
      "id": "quick-search-popup@local.ext",
      "strict_min_version": "109.0"
    }
  },
  "permissions": ["storage"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Quick Search Popup"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": { "default": "Ctrl+Shift+Space" },
      "description": "Open Popup"
    }
  }
}
